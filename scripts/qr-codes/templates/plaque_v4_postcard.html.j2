{#-
  Plaque V4 · Postcard collage
  Required: ssid, password, and one of qr_svg / qr_data_url
  Optional: accent (default #e58a3b), greeting (default "the wifi.")
-#}
{%- macro colorize(text) -%}
{%- for ch in text -%}
{%- if ch.isalpha() %}<span class="ch-letter">{{ ch }}</span>
{%- elif ch.isdigit() %}<span class="ch-digit">{{ ch }}</span>
{%- elif ch == ' ' %}<span class="ch-space">&nbsp;</span>
{%- else %}<span class="ch-symbol">{{ ch | e }}</span>
{%- endif -%}
{%- endfor -%}
{%- endmacro -%}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>WiFi · {{ ssid }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Shadows+Into+Light&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1714;
    --paper: #fdfcf8;
    --muted: #6b635a;
    --accent: {{ accent | default('#e58a3b') }};
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: #f0eee9; font-family: "Kalam", system-ui, sans-serif; color: var(--ink); }
  .stage { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
  .plaque {
    aspect-ratio: 14 / 10;
    width: min(96vw, calc(96vh * 14 / 10));
    background: var(--paper);
    overflow: hidden;
    display: grid; grid-template-columns: 1fr 1.2fr;
    gap: 4%; padding: 5%; align-items: stretch;
    container-type: inline-size;
  }
  .polaroid-wrap { display: flex; align-items: center; justify-content: center; }
  .polaroid {
    background: #fff;
    border: 2px solid var(--ink);
    padding: 5% 5% 11%;
    transform: rotate(-2.5deg);
    box-shadow: 6px 6px 0 var(--ink);
    width: 80%;
  }
  .qr {
    aspect-ratio: 1 / 1; width: 100%;
    background: #fff;
  }
  .qr svg, .qr img { width: 100%; height: 100%; display: block; }
  .polaroid-caption { text-align: center; margin-top: 10px; font-family: "Shadows Into Light", cursive; font-size: 22px; }
  .text-col { display: flex; flex-direction: column; justify-content: center; gap: 4%; }
  .hero-wrap { position: relative; display: inline-block; align-self: flex-start; }
  .hero { font-family: "Kalam", cursive; font-weight: 700; font-size: 96px; line-height: .95; }
  .hero-highlight { position: absolute; left: 0; right: 12%; bottom: 4%; height: 16%; background: var(--accent); opacity: .35; z-index: -1; }
  .squiggle { width: 60%; height: 10px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 8'><path d='M0 4 Q 7.5 1 15 4 T 30 4 T 45 4 T 60 4' fill='none' stroke='%231a1714' stroke-width='1.2'/></svg>");
    background-repeat: repeat-x; background-size: 60px 8px; }
  .label-tiny { font-family: "JetBrains Mono", ui-monospace, monospace; text-transform: uppercase; font-size: 16px; letter-spacing: .18em; color: var(--muted); margin-bottom: 6px; }
  .field-stack { display: flex; flex-direction: column; gap: 4%; }
  .value {
    font-family: "JetBrains Mono", monospace; font-size: 60px; line-height: 1;
    padding-bottom: 12px; word-break: break-all;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 6'><path d='M0 3 Q 7.5 0 15 3 T 30 3 T 45 3 T 60 3' fill='none' stroke='%231a1714' stroke-width='1.4'/></svg>");
    background-repeat: repeat-x; background-position: bottom left; background-size: 60px 6px;
  }
  @media print {
    @page { size: 14in 10in; margin: 0; }
    html, body { background: #fff; }
    .stage { padding: 0; min-height: auto; }
    .plaque { width: 14in; height: 10in; }
  }

  .ch-letter { color: var(--ink); }
  .ch-digit  { color: #1f5fd9; }
  .ch-symbol { color: #c0392b; }
  .ch-space  { display: inline-block; }

</style>
</head>
<body>
<div class="stage">
  <div class="plaque">
    <div class="polaroid-wrap">
      <div class="polaroid">
        <div class="qr">
          {%- if qr_svg %}{{ qr_svg | safe }}
          {%- elif qr_data_url %}<img src="{{ qr_data_url }}" alt="WiFi QR code">
          {%- endif %}
        </div>
        <div class="polaroid-caption">point your camera here</div>
      </div>
    </div>
    <div class="text-col">
      <div class="hero-wrap">
        <div class="hero">{{ greeting | default('the wifi.') }}</div>
        <div class="hero-highlight"></div>
      </div>
      <div class="squiggle"></div>
      <div class="field-stack">
        <div>
          <div class="label-tiny">Network</div>
          <div class="value">{{ colorize(ssid) }}</div>
        </div>
        <div>
          <div class="label-tiny">Password</div>
          <div class="value">{{ colorize(password) }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
