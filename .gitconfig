[init]
    defaultBranch = main
[user]
    email = me@darrickross.com
    name = Darrick Ross
    signingkey = DF1B93A0B3CDCF394B9D2708108B3A7D41B13305
[credential "https://github.com"]
    helper = !gh auth git-credential
[credential "https://gist.github.com"]
    helper = !gh auth git-credential
[gpg]
    # Wrapper deployed by home-manager (modules/wsl.nix): forwards to the
    # Windows Gpg4win gpg.exe on WSL2, falls through to the system gpg elsewhere.
    program = /home/itsjustmech/.local/bin/gpg
    format = openpgp
[commit]
    gpgSign = true
