[init]
    defaultBranch = main
[user]
    email = me@darrickross.com
    name = Darrick Ross
    signingkey = DF1B93A0B3CDCF394B9D2708108B3A7D41B13305
[credential "https://github.com"]
    helper = !gh auth git-credential
[credential "https://gist.github.com"]
    helper = !gh auth git-credential
[gpg]
    format = openpgp
[commit]
    gpgSign = true
[include]
    # Machine-specific values generated by home-manager (modules/wsl.nix):
    # gpg.program pointing at this machine's absolute wrapper path, derived
    # from home.homeDirectory instead of hardcoded here. Git tilde-expands
    # the path and silently skips the include when the file does not exist,
    # so this tracked file stays portable.
    path = ~/.gitconfig.local
