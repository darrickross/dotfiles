{
  // Workspace level holds only conventions specific to this repo's files.
  // Editor style lives in User settings (dotfiles-windows repo); WSL
  // machine paths live in .vscode-server/data/Machine/settings.json
  // (deployed by home-manager). Spelling uses cspell.config.yaml, not
  // cSpell.words here.
  "files.associations": {
    "config": "ssh_config",
    "*.ssh_config": "ssh_config"
  }
}
