# Secrets and credentials
*.env
.env*
*credentials*
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa
*.secret
*.secrets
# Bitwarden secrets — encrypted file lives here, never committed
.local/secrets/

# SSH: ignore everything by default, then allowlist the configs we track.
# Keys (id_*, yubikey_sk_*), known_hosts, control sockets, and machine-local
# configs (e.g. local_network.ssh_config) all stay untracked automatically.
.ssh/*
!.ssh/config
!.ssh/configs/
.ssh/configs/*
!.ssh/configs/github.ssh_config

# AWS credentials (config/profiles are fine, not actual keys)
.aws/credentials

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
*.swp
*.swo
*~
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
dist/
build/

# Node
node_modules/

# Nix build outputs
result
result-*
